# Optional for local development. If left empty, Lovely Eye generates a random
# secret on startup and dashboard sessions are invalidated on restart.
# Set a fixed value in production or multi-instance deployments.
JWT_SECRET=

# Optional
PORT=8080
ALLOW_REGISTRATION=false

# Cookie security (default: true for production Docker images)
SECURE_COOKIES=false

# PostgreSQL only (docker-compose.postgres.yml)
POSTGRES_USER=lovely
POSTGRES_PASSWORD=lovely
POSTGRES_DB=lovely_eye

INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_PASSWORD=lovely-eye
